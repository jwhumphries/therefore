{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>jwhumphries/renovate-config"
  ],
  "baseBranchPatterns": [
    "dev"
  ],
  "minimumReleaseAge": null,
  "platformAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Docker images in Dagger pipeline",
      "fileMatch": [
        "^\\.dagger/main\\.go$"
      ],
      "matchStrings": [
        "From\\(\"(?<depName>[^\"]+?):(?<currentValue>[^@\"]+?)(?:@(?<currentDigest>sha256:[a-f0-9]+))?\"\\)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Automerge minor changes",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    }
  ]
}